<mvc:View
    controllerName="dboperations.controller.Projects"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
>
    <Page
        id="ProjectsPage"
        title="Projects"
    >
        <headerContent>
            <Button
                id="btnAddProject"
                icon="sap-icon://add"
                tooltip="Add"
                text="New Project"
                press="onNavigateToAddProject"
            />
            <Button id="btnProjectDetails" icon="sap-icon://information" text="Details" tooltip="Details" press="onDetails" enabled="false" />
            <Button id="btnEditProject" icon="sap-icon://edit" text="Edit" tooltip="Edit" press="onEditProject" enabled="false" />
            <Button id="btnProjectAddBuilding" icon="sap-icon://sys-add" text="Add Building" tooltip="Add Building" press="onAddBuilding" enabled="false" />
            <Button id="btnDeleteProject" icon="sap-icon://delete" type="Reject" text="Delete" tooltip="Delete" press="onDelete" enabled="false" />
        </headerContent>

        <content>
            <ScrollContainer id="_IDGenScrollContainer3"
                horizontal="true"
                vertical="false"
                height="100%"
                width="100%"
                focusable="true"
            >
                <Table
                    id="projectsTable"
                    items="{projects>/Projects}"
                    width="150%"
                    mode="SingleSelectLeft"
                    selectionChange="onProjectSelectionChange"
                    noDataText="No projects available. Please check your connection or try again later."
                >
                    <columns>
                        <Column id="_IDGenColumn32"><Text id="_IDGenText52" text="Project ID" /></Column>
                        <Column id="_IDGenColumn33"><Text id="_IDGenText53" text="Project Description" /></Column>
                        <Column id="_IDGenColumn34"><Text id="_IDGenText54" text="Company Code ID" /></Column>
                        <Column id="_IDGenColumn35"><Text id="_IDGenText55" text="Company Code Description" /></Column>
                        <Column id="_IDGenColumn36"><Text id="_IDGenText56" text="Valid From" /></Column>
                        <Column id="_IDGenColumn37"><Text id="_IDGenText57" text="Valid To" /></Column>
                        <Column id="_IDGenColumn38"><Text id="_IDGenText58" text="Location" /></Column>

                    </columns>

                    <items>
                        <ColumnListItem id="_IDGenColumnListItem4">
                            <cells>
                                    <Text id="_IDGenText64" text="{projects>projectId}" />
                                    <Text id="_IDGenText65" text="{projects>projectDescription}" />
                                    <Text id="_IDGenText66" text="{projects>companyCodeId}" />
                                    <Text id="_IDGenText67" text="{projects>companyCodeDescription}" />
                                    <Text id="_IDGenText68" text="{projects>validFrom}" />
                                    <Text id="_IDGenText69" text="{projects>validTo}" />
                                    <Text id="_IDGenText70" text="{projects>location}" />
                                    <Text id="_IDGenText72" text="{projects>profitCenter}" />
                                    <Text id="_IDGenText73" text="{projects>functionalArea}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>
