<mvc:View
    controllerName="dboperations.controller.EOI"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
>
    <Page
        id="eoiPage"
        title="EOI Management"
    >
        <headerContent>
            <Button
                id="btnAddEOI"
                icon="sap-icon://add"
                text="New EOI"
                press="onNavigateToAddEOI"
            />
            <Button id="btnEoiDetails" icon="sap-icon://information" text="Details" press="onDetails" enabled="false" />
            <Button id="btnEditEOI" icon="sap-icon://edit" text="Edit" press="onEditEOI" enabled="false" />
            <Button id="btnAddReservationEOI" icon="sap-icon://sys-add" text="Add Reservation" press="onAddReservationFromEOI" enabled="false" />
            <Button id="btnDeleteEOI" icon="sap-icon://delete" type="Reject" text="Delete" press="onDelete" enabled="false" />
        </headerContent>

        <VBox id="_IDGenVBox6" class="sapUiSizeCompact sapUiSmallMargin">
            <Table
                id="eoiTable"
                items="{ path: '/EOI' }"
                mode="SingleSelect"
                selectionChange="onSelectEOI"
            >
                <columns>
                    <Column id="_IDGenColumn72">
                        <Text id="_IDGenText123" text="EOI ID" />
                    </Column>
                    <Column id="_IDGenColumn108">
                        <Text id="_IDGenText131" text="EOI Type" />
                    </Column>
                    <Column id="_IDGenColumn110">
                        <Text id="_IDGenText142" text="Status" />
                    </Column>
                    <Column id="_IDGenColumn114">
                        <Text id="_IDGenText167" text="Date" />
                    </Column>
                    <Column id="_IDGenColumn124">
                        <Text id="_IDGenText171" text="Project ID" />
                    </Column>
                    <Column id="_IDGenColumn131">
                        <Text id="_IDGenText181" text="Total Value" />
                    </Column>
                    <Column id="_IDGenColumn132">
                        <Text id="_IDGenText189" text="Collected Amount" />
                    </Column>
                    <Column id="_IDGenColumn133">
                        <Text id="_IDGenText191" text="Remaining Amount" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem id="_IDGenColumnListItem13">
                        <cells>
                            <Text id="_IDGenText205" text="{eoiId}" />
                            <Text id="_IDGenText218" text="{eoiType}" />
                            <Text id="_IDGenText219" text="{status}" />
                            <Text id="_IDGenText220" text="{date}" />
                            <Text id="_IDGenText221" text="{projectId}" />
                            <Text id="_IDGenText222" text="{totalEoiValue}" />
                            <Text id="_IDGenText223" text="{collectedAmount}" />
                            <Text id="_IDGenText224" text="{remainingAmount}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>
